
<!-- Flash message go here -->

{{> _messages }}

<h3><i class="fas fa-book-reader"></i> Bird spotter</h3>

<div class="section">
    <p class="lead">Register</p>
</div>


<div class="divider"></div>

<!-- Local Login -->

            <h1 class="text-center mb-3">
                <i class="fas fa-user-plus"></i> Register
            </h1>

            <form action="/register" method="POST">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input
                            type="name"
                            id="irstName"
                            name="firstName"
                            class="form-control"
                            placeholder="Enter Name"
                            value="{{#if firstName}}{{firstName}}{{/if}}"/>


                </div>
                <div class="form-group">
                    <label for="name">Last Name</label>
                    <input
                            type="name"
                            id="lastname"
                            name="lastName"
                            class="form-control"
                            placeholder="Enter Last Name"
                            value="{{#if lastName}}{{lastName}}{{/if}}"/>

                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input
                            type="email"
                            id="email"
                            name="email"
                            class="form-control"
                            placeholder="Enter Email"
                            value="{{#if email}}{{email}}{{/if}}"/>

                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input
                            type="password"
                            id="password"
                            name="password"
                            class="form-control"
                            placeholder="Create Password"
                            value="{{#if password}}{{password2}}{{/if}}"/>
                </div>
                <div class="form-group">
                    <label for="password2">Confirm Password</label>
                    <input
                            type="password"
                            id="password2"
                            name="password2"
                            class="form-control"
                            placeholder="Confirm Password"
                            value="{{#if password2}}{{password2}}{{/if}}"/>
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    Register
                </button>
            </form>
            <p class="lead mt-4">Have An Account? <a href="/login">Login</a></p>


<!-- Google Login -->
<div class="section">
    <a href="/auth/google" class="btn red darken-1">
        <i class="fab fa-google left"></i> Log In With Google
    </a>
</div>