<div id="seshId">{{sessionId}}</div> Hello
<div class="container search-container">
    <section class="loc-info">
        <div id="b-location"> {{location.location}} a</div>
        <div id="b-longitude"> {{location.longitude}}</div>
        <div id="b-latitude">{{location.latitude}}</div>
    </section>

    {{#if message }}
        <div class="alert alert-{{message.type}}">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <h3>{{message.intro}}</h3>
            {{message.message}}
        </div>
    {{/if}}

    <p class="lead">New bird spotted!</p>
    <div class="search-box">
        <input type="text" id="filterBird" class="form-control search-bar" placeholder="Bird Name">

        <button class="bird-btn-start" id="full-list">Full List</button>
    </div>

    <br>
    <div id="bird-list">
    </div>
</div>


<script src="/js/birdSearch.js"></script>

<script src="/js/addSession.js"></script>


